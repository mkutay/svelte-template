{
  "name": "svelte-template",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "biome:check": "biome check",
    "biome:check:fix": "biome check --write",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset --local",
    "db:reset:prod": "supabase db reset --db-url",
    "db:lint": "supabase db lint --local",
    "db:deploy:prod": "supabase db push --db-url",
    "db:diff": "supabase db diff --local",
    "db:migration:new": "supabase migration new",
    "db:migration:diff": "supabase db diff -f",
    "db:migration:list": "supabase migration list --local",
    "db:dump": "supabase db dump --local --data-only --schema auth,storage --schema public -f",
    "db:generate-types": "supabase gen types typescript --local --schema public > ./src/lib/supabase/database.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@lucide/svelte": "^1.8.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@vitest/browser-playwright": "^4.1.3",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "neverthrow": "^8.2.0",
    "playwright": "^1.59.1",
    "shadcn-svelte": "^1.2.7",
    "supabase": "^2.93.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3",
    "vitest-browser-svelte": "^2.1.0"
  }
}
